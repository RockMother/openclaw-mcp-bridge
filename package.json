{
  "name": "openclaw-mcp-bridge",
  "version": "0.1.0",
  "description": "MCP bridge for OpenClaw that aggregates stdio and HTTP MCP servers with hot-reloadable configuration.",
  "type": "module",
  "private": true,
  "keywords": [
    "openclaw",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-client",
    "mcp-bridge",
    "ai-agent",
    "agent-tools",
    "stdio",
    "streamable-http",
    "typescript"
  ],
  "homepage": "https://github.com/RockMother/openclaw-mcp-bridge#readme",
  "bugs": {
    "url": "https://github.com/RockMother/openclaw-mcp-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockMother/openclaw-mcp-bridge.git"
  },
  "bin": {
    "openclaw-mcp-bridge": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "servers.example.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "mcp": "node dist/src/mcpServer.js",
    "mcp:dev": "tsx src/mcpServer.ts",
    "setup": "tsx src/cli.ts setup",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:admin": "tsx scripts/smokeAdmin.ts",
    "smoke:mcp": "tsx scripts/smokeMcp.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
